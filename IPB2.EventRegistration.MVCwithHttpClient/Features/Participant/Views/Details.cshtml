@model ParticipantResponse
@{ ViewData["Title"] = "Participant Details"; }
<h1>Participant Details</h1>
<div><hr /><dl class="row"><dt class="col-sm-2">Name</dt><dd class="col-sm-10">@Model.ParticipantName</dd><dt class="col-sm-2">Email</dt><dd class="col-sm-10">@Model.Email</dd><dt class="col-sm-2">Phone</dt><dd class="col-sm-10">@Model.Phone</dd></dl></div>
<div><a asp-action="Edit" asp-route-id="@Model.ParticipantId" class="btn btn-primary">Edit</a> | <a asp-action="Index" class="btn btn-secondary">Back to List</a></div>
