@model EventResponse
@{ ViewData["Title"] = "Event Details"; }
<h1>Event Details</h1>
<div><hr /><dl class="row"><dt class="col-sm-2">Name</dt><dd class="col-sm-10">@Model.EventName</dd><dt class="col-sm-2">Location</dt><dd class="col-sm-10">@Model.Location</dd><dt class="col-sm-2">Date</dt><dd class="col-sm-10">@Model.EventDate?.ToString("yyyy-MM-dd")</dd><dt class="col-sm-2">Status</dt><dd class="col-sm-10">@Model.Status</dd></dl></div>
<div><a asp-action="Edit" asp-route-id="@Model.EventId" class="btn btn-primary">Edit</a> | <a asp-action="Index" class="btn btn-secondary">Back to List</a></div>
