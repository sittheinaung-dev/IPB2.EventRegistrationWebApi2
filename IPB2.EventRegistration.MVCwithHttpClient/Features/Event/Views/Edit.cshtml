@model EventUpdateRequest
@{ ViewData["Title"] = "Edit Event"; }
<h1>Edit Event</h1>
<hr /><div class="row"><div class="col-md-4"><form asp-action="Edit">
    <input type="hidden" asp-for="EventId" />
    <div class="form-group"><label asp-for="EventName" class="control-label"></label><input asp-for="EventName" class="form-control" /></div>
    <div class="form-group"><label asp-for="Location" class="control-label"></label><input asp-for="Location" class="form-control" /></div>
    <div class="form-group"><label asp-for="EventDate" class="control-label"></label><input asp-for="EventDate" class="form-control" type="date" /></div>
    <div class="form-group"><label asp-for="Status" class="control-label"></label><input asp-for="Status" class="form-control" /></div>
    <div class="form-group mt-3"><input type="submit" value="Save" class="btn btn-primary" /> <a asp-action="Index" class="btn btn-secondary">Back to List</a></div>
</form></div></div>
