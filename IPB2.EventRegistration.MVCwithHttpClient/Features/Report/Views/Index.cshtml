@{ ViewData["Title"] = "Reports"; }
<h1>Reports</h1>
<div class="row">
    <div class="col-md-4"><div class="card mb-4"><div class="card-body"><h5 class="card-title">Available Events</h5><p class="card-text">View available events.</p><a asp-action="AvailableEvents" class="btn btn-primary">View Report</a></div></div></div>
    <div class="col-md-4"><div class="card mb-4"><div class="card-body"><h5 class="card-title">Search Events</h5><p class="card-text">Search events.</p>
        <form asp-action="SearchEvents" method="get"><div class="input-group"><input type="text" name="searchTerm" class="form-control" /><button type="submit" class="btn btn-primary">Search</button></div></form></div></div></div>
    <div class="col-md-4"><div class="card mb-4"><div class="card-body"><h5 class="card-title">Participants by Event</h5><p class="card-text">View participants.</p>
        <form asp-action="ParticipantsByEvent" method="get"><div class="input-group"><input type="number" name="eventId" class="form-control" /><button type="submit" class="btn btn-primary">View</button></div></form></div></div></div>
</div>
