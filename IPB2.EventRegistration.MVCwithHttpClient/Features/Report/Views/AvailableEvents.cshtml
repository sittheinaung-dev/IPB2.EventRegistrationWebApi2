@model AvailableEventsResponse
@{ ViewData["Title"] = "Available Events Report"; }
<h1>Available Events</h1>
<table class="table">
    <thead><tr><th>Event Name</th><th>Date</th><th>Location</th><th>Status</th></tr></thead>
    <tbody>
@if (Model?.Data != null) {
    @foreach (var item in Model.Data) {
        <tr><td>@item.EventName</td><td>@item.EventDate?.ToString("yyyy-MM-dd")</td><td>@item.Location</td><td>@item.Status</td></tr>
    }
}
    </tbody>
</table>
<a asp-action="Index" class="btn btn-secondary">Back to Reports</a>
