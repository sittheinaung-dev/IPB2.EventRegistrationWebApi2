@model IPB2.EventRegistrationMVC.Features.Event.EventResponse

@{
    ViewData["Title"] = "Delete Event";
}

<h1>Delete Event</h1>

<h3>Are you sure you want to delete this?</h3>
<div class="text-danger" asp-validation-summary="ModelOnly"></div>

<div>
    <dl class="row">
        <dt class="col-sm-2">Event Name</dt>
        <dd class="col-sm-10">@Model.EventName</dd>
        
        <dt class="col-sm-2">Location</dt>
        <dd class="col-sm-10">@Model.Location</dd>
        
        <dt class="col-sm-2">Date</dt>
        <dd class="col-sm-10">@Model.EventDate?.ToString("yyyy-MM-dd")</dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="EventId" />
        <input type="submit" value="Delete" class="btn btn-danger" /> |
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </form>
</div>
