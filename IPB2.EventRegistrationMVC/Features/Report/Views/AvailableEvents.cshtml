@model IPB2.EventRegistrationMVC.Features.Report.AvailableEventsResponse

@{
    ViewData["Title"] = "Available Events Report";
}

<h1>Available Events Report</h1>

<table class="table">
    <thead>
        <tr>
            <th>Event Name</th>
            <th>Location</th>
            <th>Date</th>
            <th>Status</th>
        </tr>
    </thead>
    <tbody>
@if (Model.Data != null)
{
    @foreach (var item in Model.Data) {
        <tr>
            <td>@item.EventName</td>
            <td>@item.Location</td>
            <td>@item.EventDate?.ToString("yyyy-MM-dd")</td>
            <td>@item.Status</td>
        </tr>
    }
}
    </tbody>
</table>
