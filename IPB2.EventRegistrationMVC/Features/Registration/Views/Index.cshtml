@model RegistrationListResponse

@{
    ViewData["Title"] = "Registrations";
}

<h1>Registrations</h1>

<div class="row mb-3">
    <div class="col-md-4">
        <form asp-action="Index" method="get">
            <div class="input-group">
                <select name="eventId" class="form-control" asp-items="ViewBag.Events">
                    <option value="">-- Filter by Event --</option>
                </select>
                <button type="submit" class="btn btn-outline-secondary">Filter</button>
            </div>
        </form>
    </div>
    <div class="col-md-8 text-end">
        <a asp-action="Create" class="btn btn-primary">New Registration</a>
    </div>
</div>

<table class="table">
    <thead>
        <tr>
            <th>Event</th>
            <th>Participant</th>
            <th>Date</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@if (Model.Data != null)
{
    @foreach (var item in Model.Data) {
        <tr>
            <td>@item.EventName</td>
            <td>@item.ParticipantName</td>
            <td>@item.RegisterDate.ToString("yyyy-MM-dd")</td>
            <td>@item.Status</td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.RegistrationId">Edit</a> |
                <form asp-action="Cancel" asp-route-id="@item.RegistrationId" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to cancel this registration?');">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-link p-0 text-danger" style="vertical-align: baseline;">Cancel</button>
                </form>
            </td>
        </tr>
    }
}
    </tbody>
</table>
