@model RegistrationCreateRequest

@{
    ViewData["Title"] = "New Registration";
}

<h1>New Registration</h1>

<form asp-action="Create">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <div class="form-group mb-3">
        <label asp-for="EventId" class="control-label">Event</label>
        <select asp-for="EventId" class="form-control" asp-items="ViewBag.Events">
            <option value="">-- Select Event --</option>
        </select>
        <span asp-validation-for="EventId" class="text-danger"></span>
    </div>
    <div class="form-group mb-3">
        <label asp-for="ParticipantId" class="control-label">Participant</label>
        <select asp-for="ParticipantId" class="form-control" asp-items="ViewBag.Participants">
            <option value="">-- Select Participant --</option>
        </select>
        <span asp-validation-for="ParticipantId" class="text-danger"></span>
    </div>
    <div class="form-group mt-3">
        <input type="submit" value="Register" class="btn btn-primary" />
        <a asp-action="Index" class="btn btn-secondary">Back to List</a>
    </div>
</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
